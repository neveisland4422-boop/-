print("\n四、矩阵基本运算")
print("-" * 50)

def matrix_add(A, B):
    return A + B

def matrix_multiply_element(A, B):
    return A * B

def matrix_multiply(A, B):
    return A @ B

def matrix_transpose(A):
    return A.T

A = np.array([[1, 2],
              [3, 4]])

B = np.array([[5, 6],
              [7, 8]])

print("矩阵 A：")
print(A)

print("矩阵 B：")
print(B)

print("A + B：")
print(matrix_add(A, B))

print("A * B：")
print(matrix_multiply_element(A, B))

print("A @ B：")
print(matrix_multiply(A, B))

print("A 的转置：")
print(matrix_transpose(A))


print("\n五、随机数据的统计分析")
print("-" * 50)

random_data = np.random.normal(loc=70, scale=10, size=100)

print("随机生成的前10个数据：")
print(np.round(random_data[:10], 2))

